
;; Architecture extensions
#include weak "..\ARM\ARMv7-M.ddf"

;; Memory information ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 
;; Used to define address zones within the ARM address space (Memory). 
;;
;;   Name      may be almost anything
;;   AdrSpace  must be Memory
;;   StartAdr  start of memory block
;;   EndAdr    end of memory block
;;   AccType   type of access, read-only (R), read-write (RW) or SFR (W)

[Memory]
;;         Name             AdrSpace    StartAdr    EndAdr      AccType   Width
Memory =  Periph0          Memory      0x40000000  0x400D2FFF  W  
Memory =  SystemSFR        Memory      0xE0000000  0xE00FFFFF  W  
Memory =  Flash            Memory      0x00000000  0x0001FFFF  R  
Memory =  Info1            Memory      0x00100000  0x001003FF  R  
Memory =  Info2            Memory      0x00100400  0x001007FF  R  
Memory =  Info3            Memory      0x00100800  0x00100BFF  R  
Memory =  RAM              Memory      0x20000000  0x20007FFF  RW 

TrustedRanges = true
UseSfrFilter = true

[SfrInclude]
File = PAC55XX.svd
