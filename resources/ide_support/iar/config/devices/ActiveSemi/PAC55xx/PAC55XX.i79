[FILEFORMAT]
rev=1.6

[CHIP]
name=PAC55XX
endiansupport=le
thumbsupport=true
armsupport=false
fpu=VFPv4_sp
SIMD=false

JTAG=true
SWD=true
SWO_TraceD0=false

[CORE]
name=Cortex-M4

[DDF FILE]
